{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sedhommarco/trading-copilot/data/schemas/watchlist.schema.json",
  "title": "Trading Copilot Watchlist",
  "description": "Schema for strategy watchlist JSON files in data/watchlists/",
  "type": "object",
  "required": ["last_updated", "opportunities"],
  "properties": {
    "last_updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update"
    },
    "opportunities": {
      "type": "array",
      "description": "List of current trading opportunities for this strategy",
      "items": {
        "type": "object",
        "required": ["ticker", "company_name", "conviction"],
        "properties": {
          "ticker": { "type": "string" },
          "company_name": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": ["long", "short"]
          },
          "conviction": {
            "type": "string",
            "enum": ["high", "moderate", "low"]
          },
          "current_price": { "type": "number" },
          "entry_zone": {
            "oneOf": [{ "type": "string" }, { "type": "number" }]
          },
          "stop_loss": {
            "oneOf": [{ "type": "string" }, { "type": "number" }]
          },
          "take_profit": {
            "oneOf": [{ "type": "string" }, { "type": "number" }]
          },
          "risk_pct": {
            "type": "string",
            "description": "Risk as percentage of capital, e.g. '1-2%'"
          },
          "risk_reward": {
            "type": "string",
            "description": "Risk:reward ratio, e.g. '1:3'"
          },
          "risk_percent": {
            "type": "number",
            "description": "Numeric risk percent (legacy field, prefer risk_pct string)"
          },
          "expected_holding_days": { "type": "integer", "minimum": 1 },
          "rationale": { "type": "string" },
          "catalyst": { "type": "string" },
          "trade_setup": { "type": "string" },
          "entry_trigger": { "type": "string" },
          "earnings_date": { "type": "string" },
          "crash_date": { "type": "string" },
          "drop_percent": { "type": "number" },
          "event_name": { "type": "string" },
          "date": { "type": "string" },
          "time": { "type": "string" },
          "impact": { "type": "string" },
          "tradeable_instruments": {
            "type": "array",
            "items": { "type": "string" }
          },
          "recommended_action": { "type": "string" },
          "long_ticker": { "type": "string" },
          "short_ticker": { "type": "string" },
          "long_entry": { "type": "number" },
          "short_entry": { "type": "number" },
          "long_stop": { "type": "number" },
          "short_stop": { "type": "number" },
          "target_spread": { "type": "string" },
          "type": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
