{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sedhommarco/trading-copilot/schemas/watchlist.schema.json",
  "title": "Trading Copilot Watchlist Schema",
  "description": "Schema for strategy watchlist JSON files",
  "type": "object",
  "required": ["strategy", "week_start", "week_end", "opportunities"],
  "properties": {
    "strategy": {
      "type": "string",
      "description": "Strategy identifier",
      "enum": [
        "pre_earnings_momentum",
        "post_crash_rebound",
        "volatility_plays",
        "crypto_opportunities",
        "pair_trades",
        "macro_events"
      ]
    },
    "description": {
      "type": "string",
      "description": "Human-readable strategy description"
    },
    "strategy_description": {
      "type": "string",
      "description": "Detailed strategy explanation"
    },
    "week_start": {
      "type": "string",
      "format": "date",
      "description": "Week start date (YYYY-MM-DD)"
    },
    "week_end": {
      "type": "string",
      "format": "date",
      "description": "Week end date (YYYY-MM-DD)"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update timestamp (YYYY-MM-DD)"
    },
    "risk_per_trade": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Risk per trade as decimal (e.g., 0.02 = 2%)"
    },
    "strategy_confidence": {
      "type": "string",
      "description": "Overall strategy confidence"
    },
    "strategy_risks": {
      "type": "string",
      "description": "Key risks for this strategy"
    },
    "opportunities": {
      "type": "array",
      "description": "List of trading opportunities",
      "items": {
        "type": "object",
        "required": ["ticker"],
        "properties": {
          "ticker": {
            "type": "string",
            "description": "Stock/crypto ticker symbol"
          },
          "company_name": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": ["LONG", "SHORT"]
          },
          "confidence": {
            "oneOf": [
              {"type": "number", "minimum": 0, "maximum": 100},
              {"type": "string"}
            ],
            "description": "Confidence score or label"
          },
          "confidence_label": {
            "type": "string"
          },
          "conviction": {
            "type": "string"
          },
          "current_price": {
            "type": "number"
          },
          "entry_zone": {
            "oneOf": [
              {"type": "string"},
              {"type": "number"}
            ]
          },
          "stop_loss": {
            "type": "number"
          },
          "take_profit": {
            "type": "number"
          },
          "expected_holding_days": {
            "type": "integer",
            "minimum": 1
          },
          "position_size_usd": {
            "type": "number",
            "minimum": 0
          },
          "rationale": {
            "type": "string"
          },
          "trade_setup": {
            "type": "string"
          },
          "entry_trigger": {
            "type": "string"
          },
          "earnings_date": {
            "type": "string"
          },
          "crash_date": {
            "type": "string"
          },
          "drop_percent": {
            "type": "number"
          },
          "last_week_performance": {
            "type": "string"
          },
          "recommended_date": {
            "type": "string",
            "format": "date"
          },
          "created_date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "events": {
      "type": "array",
      "description": "Macro events (for macro-events.json)",
      "items": {
        "type": "object",
        "required": ["event_name", "date"],
        "properties": {
          "event_name": {"type": "string"},
          "date": {"type": "string", "format": "date"},
          "time": {"type": "string"},
          "impact": {"type": "string"},
          "tradeable_instruments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "trade_setup": {"type": "string"},
          "recommended_action": {"type": "string"},
          "rationale": {"type": "string"},
          "confidence": {
            "oneOf": [
              {"type": "number"},
              {"type": "string"}
            ]
          }
        }
      }
    },
    "candidates": {
      "type": "array",
      "description": "Pair trade candidates (for pair-trades.json)",
      "items": {
        "type": "object",
        "required": ["long_ticker", "short_ticker"],
        "properties": {
          "long_ticker": {"type": "string"},
          "short_ticker": {"type": "string"},
          "long_entry": {"type": "number"},
          "short_entry": {"type": "number"},
          "target_spread": {
            "oneOf": [
              {"type": "string"},
              {"type": "number"}
            ]
          },
          "position_size_usd_each": {"type": "number"},
          "position_size_usd": {"type": "number"},
          "expected_holding_days": {"type": "integer"},
          "long_stop": {"type": "number"},
          "short_stop": {"type": "number"},
          "rationale": {"type": "string"},
          "confidence": {
            "oneOf": [
              {"type": "number"},
              {"type": "string"}
            ]
          }
        }
      }
    },
    "previous_week_outcomes": {
      "type": "array",
      "description": "Last week's trade outcomes",
      "items": {
        "type": "object",
        "properties": {
          "ticker": {"type": "string"},
          "predicted_direction": {"type": "string"},
          "predicted": {"type": "string"},
          "actual_outcome": {"type": "string"},
          "actual": {"type": "string"},
          "hit_target": {"type": "boolean"},
          "accuracy": {"type": "string"}
        }
      }
    }
  }
}
