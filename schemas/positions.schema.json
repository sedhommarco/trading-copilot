{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Positions Schema",
  "description": "Schema for open trading positions",
  "type": "object",
  "required": ["positions", "summary"],
  "properties": {
    "positions": {
      "type": "array",
      "description": "List of open positions",
      "items": {
        "type": "object",
        "required": [
          "instrument",
          "side",
          "units",
          "entry_price",
          "current_price"
        ],
        "properties": {
          "instrument": {
            "type": "string",
            "description": "Instrument ticker/symbol"
          },
          "ticker": {
            "type": "string"
          },
          "side": {
            "type": "string",
            "enum": ["LONG", "SHORT"],
            "description": "Position side"
          },
          "units": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Number of units held"
          },
          "entry_price": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Average entry price"
          },
          "current_price": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Current market price"
          },
          "unrealised_pnl": {
            "type": "number",
            "description": "Unrealised profit/loss in USD"
          },
          "exposure": {
            "type": "number",
            "minimum": 0,
            "description": "Total exposure"
          },
          "margin": {
            "type": "number",
            "minimum": 0,
            "description": "Margin required"
          },
          "leverage": {
            "type": "number",
            "minimum": 1,
            "description": "Leverage ratio"
          },
          "holding_days": {
            "type": "integer",
            "minimum": 0,
            "description": "Days position has been open"
          },
          "strategy": {
            "type": "string",
            "description": "Strategy used for this position"
          },
          "short_description": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "recommendations": {
            "type": "string"
          },
          "exit_strategy": {
            "type": "object",
            "properties": {
              "take_profit": {
                "type": "number",
                "minimum": 0
              },
              "stop_loss": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_positions",
        "total_unrealised_pnl",
        "total_capital"
      ],
      "properties": {
        "total_positions": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of open positions"
        },
        "long_positions": {
          "type": "integer",
          "minimum": 0
        },
        "short_positions": {
          "type": "integer",
          "minimum": 0
        },
        "total_unrealised_pnl": {
          "type": "number",
          "description": "Total unrealised P&L across all positions"
        },
        "total_exposure": {
          "type": "number",
          "minimum": 0
        },
        "total_margin_used": {
          "type": "number",
          "minimum": 0
        },
        "total_capital": {
          "type": "number",
          "minimum": 0,
          "description": "Total account capital"
        }
      }
    }
  }
}
