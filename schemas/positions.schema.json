{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sedhommarco/trading-copilot/schemas/positions.schema.json",
  "title": "Trading Copilot Positions Schema",
  "description": "Schema for journal/positions.json - current open positions",
  "type": "object",
  "required": ["positions", "summary"],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "total_open_positions": {"type": "integer", "minimum": 0},
        "total_unrealised_pnl": {"type": "number"},
        "total_margin_used": {"type": "number"},
        "total_exposure": {"type": "number"},
        "last_updated": {"type": "string", "format": "date-time"}
      }
    },
    "positions": {
      "type": "array",
      "description": "List of currently open positions",
      "items": {
        "type": "object",
        "required": ["type", "short_description", "instrument", "side"],
        "properties": {
          "type": {
            "type": "string",
            "const": "position"
          },
          "short_description": {
            "type": "string",
            "description": "Human-readable position summary"
          },
          "instrument": {
            "type": "string",
            "description": "Trading instrument"
          },
          "side": {
            "type": "string",
            "enum": ["buy", "sell"],
            "description": "Position side"
          },
          "unrealised_pnl": {
            "type": "number",
            "description": "Current unrealized P&L"
          },
          "margin": {
            "type": "number",
            "description": "Margin currently locked"
          },
          "exposure": {
            "type": "number",
            "description": "Total position exposure"
          },
          "units": {
            "type": "number",
            "description": "Number of units"
          },
          "entry_price": {
            "type": "number",
            "description": "Average entry price"
          },
          "current_price": {
            "type": "number",
            "description": "Current market price"
          },
          "current_price_datetime": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of current_price"
          },
          "exit_strategy": {
            "type": "object",
            "properties": {
              "take_profit": {"type": "number"},
              "stop_loss": {"type": "number"}
            }
          },
          "notes": {
            "type": "string",
            "description": "Perplexity analysis notes"
          },
          "recommendations": {
            "type": "string",
            "description": "Perplexity recommendations"
          }
        }
      }
    }
  }
}
