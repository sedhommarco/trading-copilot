{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sedhommarco/trading-copilot/schemas/manifest.schema.json",
  "title": "Trading Copilot Manifest Schema",
  "description": "Schema for meta/manifest.json - metadata and UI configuration",
  "type": "object",
  "required": ["generated_at", "last_global_update", "files"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Manifest generation timestamp"
    },
    "last_global_update": {
      "type": "string",
      "format": "date",
      "description": "Last data update date (YYYY-MM-DD)"
    },
    "stale_threshold_days": {
      "type": "integer",
      "minimum": 1,
      "description": "Days before data is considered stale"
    },
    "ui": {
      "type": "object",
      "properties": {
        "tab_order": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Ordered list of tab names"
        },
        "favorite_tabs": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Tabs marked as favorites"
        },
        "market_regime_collapsed_by_default": {
          "type": "boolean",
          "description": "Whether market regime section starts collapsed"
        }
      }
    },
    "files": {
      "type": "array",
      "description": "List of tracked data files",
      "items": {
        "type": "object",
        "required": ["path", "last_modified"],
        "properties": {
          "path": {"type": "string"},
          "last_modified": {"type": "string", "format": "date-time"},
          "week_start": {"type": "string", "format": "date"},
          "week_end": {"type": "string", "format": "date"},
          "opportunity_count": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
