{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sedhommarco/trading-copilot/schemas/transactions.schema.json",
  "title": "Trading Copilot Transactions Schema",
  "description": "Schema for journal/transactions.json - append-only transaction log",
  "type": "object",
  "required": ["transactions", "summary"],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "total_count": {"type": "integer", "minimum": 0},
        "total_fees": {"type": "number"},
        "last_updated": {"type": "string", "format": "date-time"}
      }
    },
    "transactions": {
      "type": "array",
      "description": "Chronological list of all transactions",
      "items": {
        "type": "object",
        "required": ["type", "short_description", "datetime", "instrument", "side"],
        "properties": {
          "type": {
            "type": "string",
            "const": "transaction"
          },
          "short_description": {
            "type": "string",
            "description": "Human-readable transaction summary"
          },
          "datetime": {
            "type": "string",
            "format": "date-time",
            "description": "Transaction timestamp (YYYY-MM-DD HH:MM:SS)"
          },
          "instrument": {
            "type": "string",
            "description": "Trading instrument (e.g., XAU/USD, BTC/USD)"
          },
          "side": {
            "type": "string",
            "enum": ["buy", "sell"],
            "description": "Transaction side"
          },
          "units": {
            "type": "string",
            "description": "Number and type of units (e.g., '2 XAU:CFD')"
          },
          "price": {
            "type": "number",
            "description": "Execution price"
          },
          "leverage": {
            "type": "string",
            "description": "Leverage used (e.g., '20x')"
          },
          "exposure": {
            "type": "number",
            "description": "Total exposure in account currency"
          },
          "fees": {
            "type": "number",
            "description": "Transaction fees"
          },
          "margin": {
            "type": "number",
            "description": "Margin required/released"
          },
          "notes": {
            "type": "string",
            "description": "Perplexity analysis notes"
          },
          "recommendations": {
            "type": "string",
            "description": "Perplexity recommendations"
          }
        }
      }
    }
  }
}
